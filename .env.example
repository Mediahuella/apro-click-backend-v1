# Cognito — values available after deploying the users service
# Check CloudFormation outputs: apro-click-admin-users stack
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# PostgreSQL (RDS) — used by services that access the database
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# Servicio users (opcional): override del UUID de empresa plataforma si no hay fila con is_system en companies.
APRO_CLICK_COMPANY_ID=

# Shopify app (Partner / Dev Dashboard) — OAuth vía servicio shopify
# https://shopify.dev/docs/apps/build/authentication-authorization/access-tokens/authorization-code-grant
SHOPIFY_CLIENT_ID=
# Necesario en Lambda para HMAC + intercambio de token en /oauth/callback; mismo secret para el webhook de pedidos
SHOPIFY_CLIENT_SECRET=
# Scopes ejemplo: read_products,write_products,read_orders,write_order_edits,read_order_edits,read_users
# read_users: vincular usuarios del panel con StaffMember (staffMembers); suele exigir tienda Plus/Advanced o habilitación en Partners
# Pedidos CRM: REST + Order Edit GraphQL; read_products hace falta si se agregan líneas por SKU (productVariants)
SHOPIFY_OAUTH_SCOPES=
# Redirect URL registrada en la app = URL pública del API + /api/v1/shopify/oauth/callback
SHOPIFY_OAUTH_REDIRECT_URI=
# Tras guardar token: 302 al conector con ?shop=&oauth_status=success&installation_id=
SHOPIFY_CONNECTOR_URL=
# Versión Admin API GraphQL (aprobar solicitudes → customerCreate en Shopify)
SHOPIFY_API_VERSION=2026-04
# (Opcional, servicio users) Invitar/crear staff: la API pública de Shopify no incluye eso. Tras un POST JSON
# con { userId, email, givenName, familyName, shopDomain } puede devolver { "shopifyStaffMemberGid": "gid://shopify/StaffMember/..." }.
# SHOPIFY_STAFF_PROVISIONER_URL=
# SHOPIFY_STAFF_PROVISIONER_API_KEY=

# Servicio company-registration: si tiene valor, el POST público exige header X-Api-Key; vacío = sin API key
COMPANY_REGISTRATION_API_KEY=

# Servicio chat (theme extension): mismo patrón; el panel usa Cognito Bearer token
CHAT_STOREFRONT_API_KEY=
